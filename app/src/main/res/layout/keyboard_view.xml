<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#000000"
    tools:ignore="HardcodedText">

    <RelativeLayout
        android:id="@+id/keyboard_header_bar"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="#1C1C1C">

        <HorizontalScrollView
            android:id="@+id/suggestion_tray"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toStartOf="@id/sms_counter_text"
            android:layout_alignParentStart="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/suggestion_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="5dp"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/sms_counter_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerInParent="true"
            android:layout_marginEnd="12dp"
            android:text="160/1"
            android:textColor="#FFD700"
            android:textSize="12sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <FrameLayout
        android:id="@+id/swipe_touch_area"
        android:layout_width="match_parent"
        android:layout_height="300dp">

        <TextView
            android:id="@+id/case_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="15dp"
            android:text="Abc"
            android:textColor="#FFD700"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView android:layout_gravity="top|center_horizontal" android:text="VOWELS (↑)" android:textColor="#333333" android:textSize="12sp" android:layout_marginTop="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:layout_gravity="bottom|center_horizontal" android:text="FLOW (↓)" android:textColor="#333333" android:textSize="12sp" android:layout_marginBottom="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:layout_gravity="center_vertical|end" android:text="POWER (→)" android:textColor="#333333" android:textSize="12sp" android:layout_marginEnd="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:layout_gravity="center_vertical|start" android:text="(←) COMPLEX" android:textColor="#333333" android:textSize="12sp" android:layout_marginStart="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/list_preview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="80dp"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:letterSpacing="0.3"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/preview_bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#FFD700"
            android:textSize="80sp"
            android:textStyle="bold"
            android:visibility="invisible" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#121212">

        <TextView
            android:id="@+id/mode_button"
            android:layout_width="65dp"
            android:layout_height="match_parent"
            android:text="ABC"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="?android:attr/selectableItemBackground" />

        <TextView
            android:id="@+id/space_bar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:text="English (US)"
            android:gravity="center"
            android:textColor="#888888"
            android:background="@android:drawable/editbox_dropdown_dark_frame" />

        <ImageView
            android:id="@+id/send_button"
            android:layout_width="55dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_send"
            android:padding="12dp"
            android:contentDescription="Send"
            android:background="?android:attr/selectableItemBackground" />

        <ImageView
            android:id="@+id/newline_button"
            android:layout_width="55dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_revert"
            android:rotation="270"
            android:padding="12dp"
            android:contentDescription="Next Line"
            android:background="?android:attr/selectableItemBackground" />
    </LinearLayout>
</LinearLayout>